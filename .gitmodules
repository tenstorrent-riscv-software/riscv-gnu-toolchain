# Some of the external git repos are not upstream servers but upstream clones to
# avoid "Server does not allow request for unadvertised object" errors (see
# #1654).
[submodule "binutils"]
	path = binutils
	url = https://github.com/tenstorrent-riscv-software/binutils-gdb.git
	branch = master
	shallow = true
[submodule "gcc"]
	path = gcc
	url = https://github.com/tenstorrent-riscv-software/gcc.git
	branch = tt-master
	shallow = true
[submodule "glibc"]
	path = glibc
	url = https://github.com/tenstorrent-riscv-software/glibc.git
	shallow = true
[submodule "gdb"]
	path = gdb
	url = https://github.com/tenstorrent-riscv-software/binutils-gdb.git
	branch = gdb-16-branch
	shallow = true
[submodule "qemu"]
	path = qemu
	url = https://github.com/tenstorrent-riscv-software/qemu.git
	shallow = true
[submodule "llvm"]
	path = llvm
	url = https://github.com/tenstorrent-riscv-software/llvm-project.git
	branch = release/20.x
	shallow = true
